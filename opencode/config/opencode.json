{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "alertmanager": {
      "type": "remote",
      "url": "http://alertmanager-mcp:8001/sse",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "google-workspace": {
      "type": "remote",
      "url": "http://google-workspace-mcp:3103/sse",
      "enabled": true
    },
    "yahoo-mail": {
      "type": "remote",
      "url": "http://yahoo-mail-mcp:3101/sse",
      "enabled": true
    },
    "tado": {
      "type": "remote",
      "url": "http://tado-mcp:3102/sse",
      "enabled": true
    },
    "todoist": {
      "type": "remote",
      "url": "http://todoist-mcp:3104/sse",
      "enabled": true
    },
    "asus-router": {
      "type": "remote",
      "url": "http://asus-router-mcp:3105/sse",
      "enabled": true
    },
    "playwright": {
      "type": "remote",
      "url": "http://playwright-mcp:3106/sse",
      "enabled": true
    }
  }
}
