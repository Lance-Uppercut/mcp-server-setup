# MCP Server Setup - Environment Variables
# Copy this file to .env and fill in your values

# Todoist
TODOIST_API_TOKEN=

# Yahoo Mail
YAHOO_EMAIL=
YAHOO_APP_PASSWORD=
YAHOO_TRANSPORT_MODE=stdio

# Google Workspace (Gmail + Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_TOKEN=

# Jenkins
JENKINS_URL=
JENKINS_USERNAME=
JENKINS_API_TOKEN=
JENKINS_VERIFY_SSL=true

# Alertmanager
ALERTMANAGER_URL=
ALERTMANAGER_USERNAME=
ALERTMANAGER_PASSWORD=
ALERTMANAGER_TRANSPORT=stdio

# SSH Servers (configure in ./ssh/config)
# See: https://man.openbsd.org/ssh_config.5

# Tado (custom MCP server)
TADO_USERNAME=
TADO_PASSWORD=
TADO_CLIENT_ID=
TADO_CLIENT_SECRET=

# Portainer MCP Servers
PORTAINER_BUILD1_TOKEN=
PORTAINER_BUILD2_TOKEN=
PORTAINER_MONITOR_TOKEN=
PORTAINER_OBSERVABILITY1_TOKEN=
PORTAINER_TOOLS1_TOKEN=
PORTAINER_PRODUCTION1_TOKEN=

# ASUS Router MCP
ROUTER_HOST=192.168.1.18
ROUTER_USERNAME=admin
ROUTER_PASSWORD=
USE_SSL=true
